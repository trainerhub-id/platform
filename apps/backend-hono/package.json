{
  "name": "trainerhub-backend-hono",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "build": "bun build src/server.ts --target=bun --outdir=dist",
    "check": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.35",
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@aws-sdk/client-s3": "^3.1047.0",
    "@aws-sdk/s3-request-presigner": "^3.1047.0",
    "@better-auth/drizzle-adapter": "^1.6.11",
    "@hono/zod-openapi": "^1.4.0",
    "@react-pdf/renderer": "^4.5.1",
    "ai": "^6.0.182",
    "better-auth": "^1.6.11",
    "docx": "^9.6.1",
    "docx-templates": "^4.15.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "jose": "^6.2.3",
    "pg-boss": "^12.18.2",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "jszip": "^3.10.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6"
  }
}
